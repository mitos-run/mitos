FROM golang:1.26-bookworm@sha256:b305420a68d0f229d91eb3b3ed9e519fcf2cf5461da4bef997bf927e8c0bfd2b AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
# The stub Prepares and (slice 2) activates a Firecracker VMM, so it is a
# linux/amd64 binary; CGO is off for a static binary like forkd.
RUN CGO_ENABLED=0 go build -o husk-stub ./cmd/husk-stub/

FROM ubuntu:22.04@sha256:4f838adc7181d9039ac795a7d0aba05a9bd9ecd480d294483169c5def983b64d

LABEL org.opencontainers.image.title="mitos-husk-stub" \
      org.opencontainers.image.description="Mitos husk-stub: pod-native warm sandbox runner." \
      org.opencontainers.image.source="https://github.com/mitos-run/mitos" \
      org.opencontainers.image.url="https://mitos.run" \
      org.opencontainers.image.documentation="https://mitos.run/docs" \
      org.opencontainers.image.vendor="Mitos" \
      org.opencontainers.image.licenses="Apache-2.0"

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        iproute2 \
        nftables \
    && rm -rf /var/lib/apt/lists/*
# iproute2 (ip) and nftables (nft) are REQUIRED by the in-pod egress filter the
# stub programs at activation (internal/husk/netfilter.go + internal/netconf):
# it shells out to `ip tuntap add` / `ip addr`/`ip link` to create the VM tap and
# `nft -f` to install the default-deny + metadata-block chain in the pod netns.
# Without them activation fails with `exec: "ip": executable file not found`.

# Install Firecracker AND the matching jailer, mirroring Dockerfile.forkd via the
# shared hack/install-firecracker.sh: the stub spawns a dormant Firecracker VMM
# through the jailer, so both binaries ship at the same paths forkd uses
# (/usr/local/bin/{firecracker,jailer}), which the stub and the controller-built
# pod spec point at. The script fails the build if either is missing (#425).
ARG FC_VERSION=v1.15.0
COPY hack/install-firecracker.sh /tmp/install-firecracker.sh
# Swap the stock firecracker for the Mitos-patched VMM (live-fork: memfd/MAP_SHARED
# + UFFD-WP), keeping the stock jailer. Pinned by sha256; behaviour-identical to
# stock v1.15.0 until FIRECRACKER_MITOS_* env is set at runtime (m4b), so this swap
# is a no-op for stock behaviour. Runs inside this RUN so it uses the same curl the
# stock install needs, before curl is purged. Revert = drop this COPY + the patched
# script call. See hack/install-firecracker-patched.sh for provenance.
COPY hack/install-firecracker-patched.sh /tmp/install-firecracker-patched.sh
RUN apt-get update -qq && apt-get install -y --no-install-recommends curl && \
    chmod +x /tmp/install-firecracker.sh /tmp/install-firecracker-patched.sh && \
    FC_VERSION="${FC_VERSION}" /tmp/install-firecracker.sh && \
    /tmp/install-firecracker-patched.sh && \
    rm -f /tmp/install-firecracker.sh /tmp/install-firecracker-patched.sh && \
    apt-get purge -y curl && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/husk-stub /usr/local/bin/husk-stub

# The guest KERNEL is NOT baked into this image. Like forkd's snapshot/data
# artifacts, the kernel is a runtime artifact provided to the pod via a volume
# mount under /var/lib/mitos (the controller-built husk pod points
# --kernel at /var/lib/mitos/kernel/vmlinux). This keeps the image
# kernel-agnostic; the running pod + its volume layout are exercised in the
# kind-e2e slice.
VOLUME ["/var/lib/mitos", "/run/husk"]

ENTRYPOINT ["/usr/local/bin/husk-stub"]
